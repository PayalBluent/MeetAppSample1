# MeetApp — copy this file to `.env` and fill in your keys.
# Loaded automatically at startup; values prefill Settings → AI Services.

# AssemblyAI — https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Groq — https://console.groq.com/
GROQ_API_KEY=

# Optional: override the Groq model (https://console.groq.com/docs/models).
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: DeepFilterNet noise-suppression preprocessing before AssemblyAI.
# Only active in builds compiled with `--features deepfilter` AND with the
# `deep-filter` CLI installed; otherwise transcription silently uses the original
# audio. Set to 0/false to force-disable a feature-compiled build.
# MEETAPP_DEEPFILTER=1
# MEETAPP_DEEPFILTER_BIN=deep-filter
# MEETAPP_DEEPFILTER_ARGS=
