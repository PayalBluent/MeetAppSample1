# MeetApp — copy this file to `.env` and fill in your keys.
# Loaded automatically at startup; values prefill Settings → AI Services.

# AssemblyAI — https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Groq — https://console.groq.com/
GROQ_API_KEY=

# Optional: override the Groq model (https://console.groq.com/docs/models).
GROQ_MODEL=llama-3.3-70b-versatile
